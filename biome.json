{
	"$schema": "https://biomejs.dev/schemas/2.4.7/schema.json",
	"formatter": {
		"indentStyle": "tab",
		"indentWidth": 2
	},
	"linter": {
		"enabled": true,
		"rules": { "recommended": true }
	},
	"javascript": {
		"formatter": { "quoteStyle": "double" }
	},
	"css": {
		"parser": {
			"tailwindDirectives": true
		}
	},
	"files": {
		"includes": [
			"src/**",
			"scripts/**",
			"drizzle/**",
			"!drizzle/migrations/meta"
		]
	}
}
